// Isso diz ao Prisma como se conectar (usando o .env)
datasource db {
  provider = "postgresql"
}

// Isso gera o cliente TypeScript que usaremos no Express
generator client {
  provider = "prisma-client-js"
}

// --- NOSSAS TABELAS ---

model Coordenacao {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome            String   @db.VarChar(255)
  sigla           String   @db.VarChar(20)
  descricao       String?  @db.Text
  icone           String?  @db.VarChar(50)
  ordem_exibicao  Int?
  
  // Relacionamento: Uma coordenação tem vários avisos
  avisos          Aviso[]

  @@map("coordenacoes") // Nome da tabela no banco
}

model Aviso {
  id              String      @id @default(uuid())
  
  titulo          String      @db.Text
  descricao       String?     @db.Text
  link_anexo      String?     @db.Text
  
  ativo           Boolean     @default(true)
  data_publicacao DateTime    @default(now())
  
  // 👇 ADICIONE O @db.Uuid NESTA LINHA 👇
  coordenacaoId   String?     @db.Uuid
  coordenacao     Coordenacao? @relation(fields: [coordenacaoId], references: [id])

  @@map("avisos")
}

model ComunicadoCarrossel {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titulo          String   @db.VarChar(255)
  imagem_url      String   @db.VarChar(255)
  link_destino    String?  @db.VarChar(255)
  ordem_exibicao  Int?
  ativo           Boolean  @default(true)

  @@map("comunicados_carrossel")
}

// Adicione este bloco para definir os estados possíveis do usuário
enum UserStatus {
  PENDENTE
  APROVADO
  BLOQUEADO
}

model Usuario {
  id         String     @id @default(uuid())
  nome       String
  email      String     @unique
  senha      String
  cargo      String
  
  // 👇 AS GAVETAS NOVAS AQUI 👇
  cpf        String?
  unidade    String?

  status     UserStatus @default(PENDENTE)

  // No PostgreSQL, o Prisma permite salvar uma lista de strings diretamente
  // Aqui guardaremos as chaves das permissões, ex: ["mural", "indicadores"]
  permissoes String[]   @default([])

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@map("usuarios")
}

model Documento {
  id              Int      @id @default(autoincrement())
  titulo          String
  descricao       String?
  nome_arquivo    String
  tipo_extensao   String
  tamanho         Int
  url_caminho     String
  data_cadastro   DateTime @default(now())
  criado_por_nome String?
}

model Paciente {
  id              Int           @id @default(autoincrement())
  cpf             String?       @unique // <-- O '?' torna opcional
  cns             String?       @unique // <-- O '?' torna opcional
  nome            String        // Nome continua sem '?', pois é obrigatório
  data_nascimento String?       // <-- opcional
  idade           Int?          // <-- opcional
  sexo            String?
  registro_hc     String?       
  prescricoes     Prescricao[]
  createdAt       DateTime      @default(now())
}

model Prescricao {
  id               Int      @id @default(autoincrement())
  paciente         Paciente @relation(fields: [pacienteId], references: [id])
  pacienteId       Int
  setor            String
  leito            String?
  custo            String?
  data_prescricao  DateTime @default(now())
  itens            Json     // Vamos salvar a lista de medicamentos/dietas como um JSON para facilitar
  medico_nome      String
  status           String   @default("ATIVA") // ATIVA, ENCERRADA, CANCELADA
}

